{
  "name": "voicer-mac",
  "private": true,
  "version": "0.1.0",
  "description": "Voicer macOS Desktop",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run build:electron && electron .",
    "electron:build": "npm run build:electron && electron-builder --mac",
    "electron:build:dir": "npm run build:electron && electron-builder --mac --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.voicer.app",
    "productName": "Voicer",
    "directories": {
      "output": "release"
    },
    "files": [
      "../web/dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    }
  }
}
